<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head", { pageTitle: "Luxe Bites | Contact" }) %>
</head>
<body>
  <%- include("partials/navbar") %>

  <main class="page-shell">
    <section class="page-hero">
      <div class="page-hero-copy">
        <p class="eyebrow">Contact</p>
        <h1>Reach the team behind the experience.</h1>
        <p>Whether it’s an event inquiry, private dining request, or general question, the contact UI stays clean, premium, and highly accessible.</p>
      </div>
      <aside class="page-hero-card">
        <div>
          <p class="eyebrow">Hospitality Desk</p>
          <h3>Private events, curated menus, and concierge-style support.</h3>
        </div>
      </aside>
    </section>

    <section class="contact-grid">
      <div class="auth-panel reveal">
        <p class="eyebrow">Message Us</p>
        <h1>Start the conversation.</h1>
        <form action="/contact" method="POST" class="auth-card form-grid">
          <div class="form-group">
            <label for="contact-name">Full name</label>
            <input id="contact-name" type="text" name="name" class="form-input" placeholder="Enter your name" required>
          </div>
          <div class="form-group">
            <label for="contact-email">Email address</label>
            <input id="contact-email" type="email" name="email" class="form-input" placeholder="you@example.com" required>
          </div>
          <div class="form-group">
            <label for="contact-message">Message</label>
            <textarea id="contact-message" name="message" class="form-textarea" rows="6" placeholder="Tell us how we can help" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Send Message</button>
        </form>
      </div>

      <div class="admin-stack">
        <article class="contact-card reveal">
          <div class="contact-icon"><i class="bi bi-geo-alt"></i></div>
          <h3>Visit Us</h3>
          <p class="lead">28 Ember Street, Culinary District, Downtown.</p>
        </article>
        <article class="contact-card reveal">
          <div class="contact-icon"><i class="bi bi-telephone"></i></div>
          <h3>Call</h3>
          <p class="lead">+1 (555) 123-4567 for bookings and dining support.</p>
        </article>
        <article class="contact-card reveal">
          <div class="contact-icon"><i class="bi bi-envelope"></i></div>
          <h3>Email</h3>
          <p class="lead">hello@luxebites.com for events, collaborations, and concierge requests.</p>
        </article>
      </div>
    </section>

    <section class="section" style="padding-top: 2rem;">
      <div class="map-card reveal">
        <div>
          <p class="eyebrow">Location Preview</p>
          <h3>Immersive map placeholder for a future integration.</h3>
          <p class="lead">The UI already reserves polished space for location visuals without adding backend or API logic.</p>
        </div>
      </div>
    </section>
  </main>

  <%- include("partials/footer") %>
  <script src="/js/main.js"></script>
</body>
</html>
