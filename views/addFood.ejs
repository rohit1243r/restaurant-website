<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head", { pageTitle: "Luxe Bites | Add Food" }) %>
</head>
<body>
  <%- include("partials/navbar") %>

  <main class="page-shell">
    <section class="split-shell">
      <div class="auth-panel reveal">
        <p class="eyebrow">Admin Menu Builder</p>
        <h1>Add a new premium dish.</h1>
        <form action="/add-food" method="POST" enctype="multipart/form-data" class="auth-card form-grid">
          <div class="form-group">
            <label for="food-name">Food name</label>
            <input id="food-name" type="text" name="name" class="form-input" placeholder="Enter dish name" required>
          </div>
          <div class="form-grid two">
            <div class="form-group">
              <label for="food-price">Price</label>
              <input id="food-price" type="number" name="price" class="form-input" placeholder="Enter price" required>
            </div>
            <div class="form-group">
              <label for="food-category">Category</label>
              <input id="food-category" type="text" name="category" class="form-input" placeholder="Pasta, Burger, Dessert..." required>
            </div>
          </div>
          <div class="form-group">
            <label for="food-image">Food image</label>
            <input id="food-image" type="file" name="image" class="form-input" required>
          </div>
          <div class="form-group">
            <label for="food-description">Description</label>
            <input id="food-description" type="text" name="description" class="form-input" placeholder="Short premium description" required>
          </div>
          <button type="submit" class="btn btn-primary">Add Food</button>
        </form>
      </div>

      <div class="newsletter-card reveal">
        <p class="eyebrow">Preview Intent</p>
        <h2>Designed to keep admin actions visually consistent.</h2>
        <p class="lead">This form uses the same spacing, glass surfaces, and dark luxury styling as the public-facing pages to keep the whole app cohesive.</p>
      </div>
    </section>
  </main>

  <script src="/js/main.js"></script>
</body>
</html>
